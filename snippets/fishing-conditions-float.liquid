{% comment %}
  Floating fishing conditions widget (FAB + slide-up panel).
  Include once in theme.liquid just before </body>:
    {% render 'fishing-conditions-float' %}

  Controlled via theme customizer section "Fishing Conditions Float".
  Settings are read from global settings_data or can be hardcoded here.
{% endcomment %}

{%- assign show_float = settings.fishing_float_enabled | default: true -%}

