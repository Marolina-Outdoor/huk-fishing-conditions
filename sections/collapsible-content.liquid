{{- 'collapsible-content.css' | asset_url | stylesheet_tag -}}

{% if template.name contains 'product' %}
  <style>
    .section-header--content {
      width: 100%;
    }
    .icons-wrapper {
      display: flex;
      flex-wrap: wrap;
    }
    .feature-icon {
      list-style: none;
      width: 50%;
      font-size: 15px;
      margin-bottom: 20px;
    }

    .feature-icon img {
      width: 24px;
      height: 24px;
      margin-right: 16px;
    }
    .section-header--content p,
    .section-header--content ul li {
      font-size: 15px;
    }

    @media screen and (max-width: 768px) {
      .feature-icon {
        width: 100%;
      }
    }
  </style>
{% endif %}

{%- liquid
  assign section_heading = section.settings.heading
  assign marker_style = section.settings.marker_style
  assign section_description = section.settings.description

  assign color_bg = section.settings.color_bg | downcase
  assign color_heading = section.settings.color_heading
  assign marker_color = section.settings.marker_color
  assign color_text = section.settings.color_text
  assign color_links = section.settings.color_links
  assign color_border = section.settings.color_border
  assign color_body_bg = settings.color_body_bg | downcase

  assign disable_top_spacing = section.settings.disable_top_spacing
  assign disable_bottom_spacing = section.settings.disable_bottom_spacing

  assign has_bg = true
  if color_body_bg == color_bg or color_bg == 'transparent' or color_bg == 'rgba(0,0,0,0)'
    assign has_bg = false
  endif
  assign product_metafield = product.metafields.custom.link_to_products
  assign feature_icons = product_metafield.value.feature_icons
-%}

{% assign description_content = section_description %}

{% if template.name contains 'product' %}
  {% if section_description contains '[product_description]' %}
    {% assign description_content = product.description %}
  {% endif %}
{% endif %}
{% capture section-header %}
	{% render 'section-header', blocks: section.blocks, section_name: 'Collapsible content', section_icon: icon_1_image, section_heading: section_heading, section_description: description_content, marker_color: marker_color, marker_style: marker_style %}
{% endcapture %}

{% capture section-content %}
	<div id="{{ section.settings.id }}" class="collapsible-content__inner">


		{%- for block in section.blocks -%}
      {% unless feature_icons.value.count == blank and block.settings.content contains "[feature_highlights]"%}
      {% unless block.settings.content == blank and block.settings.heading != "Fit" and block.settings.page.content == blank and block.settings.heading != "Description" and template.name contains 'product' %}
        {%- if block.settings.heading != blank and block.type == 'collapsible_tab' -%}
        <collapsible-row class="accordion"  {% if block.settings.heading == "Fit" and product.metafields.custom.fit_info == blank %} style="display:none;"  {% endif %} {{ block.shopify_attributes }}>
            <details id="Details-{{ block.id }}-{{ section.id }}" {% if block.settings.open %}open{% endif %}>
              <summary>
                {{ block.settings.heading | default: block.settings.page.title }}
                <span>{%- render 'svg-icons' with 'thb-collapsible-arrow' -%}</span>
              </summary>
              <div class="collapsible__content accordion__content rte" id="Accordion-{{ block.id }}-{{ section.id }}">
                {% if block.settings.content contains "[feature_highlights]"%}
                  <div class="icons-wrapper">
                  {% for feature in feature_icons.value%}
                      <li class="feature-icon">
                        {%- render 'responsive-image', image: feature.icon.value, sizes: '20x20,40x40' -%}
                        {{ feature.icon_text }}
                      </li>
                  {% endfor %}
                  </div>
                {% elsif block.settings.heading == "Fit" and template.name contains 'product' %}
                  {{ product.metafields.custom.fit_info }}
                {% else %}
                  {{ block.settings.content }}
                  {{ block.settings.page.content }}
                {% endif %}
              </div>
            </details>
          </collapsible-row>
			{%- endif -%}
    {% endunless %}
  {% endunless %}
{%- endfor -%}
	</div>
{% endcapture %}

<div class="row">
  <div class="small-12 columns">
    <div
      class="collapsible-content collapsible-content-desktop {% if has_bg %}collapsible-content--has-bg{% endif %} section-spacing{% if disable_top_spacing %} section-spacing--disable-top{% endif %}{% if disable_bottom_spacing %} section-spacing--disable-bottom{% endif %}"
      style="--color-bg: {{ color_bg }}; --color-heading: {{ color_heading }}; --color-text: {{ color_text }}; --color-links: {{ color_links }}; --color-border: {{ color_border }};"
      {% if template.name == 'product' %}
        data-product-template="true"
      {% endif %}
    >
      {% if section.settings['section-reverse'] == false %}
        {{ section-header }}
        {{ section-content }}
      {% elsif section.settings['section-reverse'] == true %}
        {{ section-content }}
        {{ section-header }}
      {% endif %}
    </div>
    <div
      class="collapsible-content collapsible-content-mobile {% if has_bg -%}collapsible-content--has-bg{% endif %} section-spacing{% if disable_top_spacing %} section-spacing--disable-top{% endif %}{% if disable_bottom_spacing %} section-spacing--disable-bottom{% endif %}"
      style="--color-bg: {{ color_bg }}; --color-heading: {{ color_heading }}; --color-text: {{ color_text }}; --color-links: {{ color_links }}; --color-border: {{ color_border }};"
      {% if template.name == 'product' %}
        data-product-template="true"
      {% endif %}
    >
      {% if section.settings['section-reverse-mobile'] == false %}
        {{ section-header }}
        {{ section-content }}
      {% elsif section.settings['section-reverse-mobile'] == true %}
        {{ section-content }}
        {{ section-header }}
      {% endif %}
    </div>
  </div>
</div>
{% schema %}
{
  "name": "Collapsible content",
  "settings": [
    {
      "type": "text",
      "id": "id",
      "label": "section id"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Collapsible content",
      "info": "Wrap your text between | to add animated markers. For example: Animated |marker| will underline marker text."
    },
    {
      "type": "select",
      "id": "marker_style",
      "options": [
        {
          "value": "style1",
          "label": "Basic"
        },
        {
          "value": "style2",
          "label": "Double"
        },
        {
          "value": "style3",
          "label": "Squiggle"
        },
        {
          "value": "style4",
          "label": "Zigzag"
        }
      ],
      "default": "style1",
      "label": "Marker"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Add a short description for this section</p>"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "color_bg",
      "label": "Background",
      "default": "transparent"
    },
    {
      "type": "color",
      "id": "color_heading",
      "label": "Heading",
      "default": "#1a1c1d"
    },
    {
      "type": "color",
      "id": "marker_color",
      "label": "Marker",
      "default": "#FD6262"
    },
    {
      "type": "color",
      "id": "color_text",
      "label": "Text",
      "default": "#2c2d2e"
    },
    {
      "type": "color",
      "id": "color_links",
      "label": "Links",
      "default": "#2c2d2e"
    },
    {
      "type": "color",
      "id": "color_border",
      "label": "Border",
      "default": "#DADCE0"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "checkbox",
      "id": "disable_top_spacing",
      "default": false,
      "label": "Remove top spacing"
    },
    {
      "type": "checkbox",
      "id": "disable_bottom_spacing",
      "default": false,
      "label": "Remove bottom spacing"
    },
    {
      "type": "checkbox",
      "id": "section-reverse",
      "default": false,
      "label": "Reverse section header and content layout"
    },
    {
      "type": "checkbox",
      "id": "section-reverse-mobile",
      "default": false,
      "label": "Reverse section header and content layout for mobile"
    }
  ],
  "blocks": [
    {
      "type": "feature_highlights",
      "name": "Feature Highlights",
      "settings": [
        {
          "type": "text",
          "id": "tab_title",
          "default": "Feature Highlights",
          "info": "Include a heading that explains the content.",
          "label": "Heading"
        },
        {
          "type": "image_picker",
          "id": "icon_1_icon",
          "label": "Custom icon",
          "info": "40 x 40 .png recommended."
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Collapsible content",
          "info": "Wrap your text between | to add animated markers. For example: Animated |marker| will underline marker text."
        }
      ]
    },
    {
      "type": "collapsible_tab",
      "name": "Collapsible row",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "default": "Collapsible row",
          "info": "Include a heading that explains the content.",
          "label": "Heading"
        },
        {
          "type": "checkbox",
          "id": "open",
          "default": false,
          "label": "Open by default"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Row content"
        },
        {
          "type": "page",
          "id": "page",
          "label": "Row content from page"
        },
        {
          "type": "image_picker",
          "id": "icon_1_icon",
          "label": "Custom icon",
          "info": "40 x 40 .png recommended."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collapsible content",
      "blocks": [
        {
          "type": "collapsible_tab"
        },
        {
          "type": "collapsible_tab"
        },
        {
          "type": "collapsible_tab"
        },
        {
          "type": "collapsible_tab"
        },
        {
          "type": "collapsible_tab"
        }
      ]
    }
  ]
}
{% endschema %}
