{% comment %}
  Fishing Conditions Section
  Displays local weather, tide, and fishing score using
  Open-Meteo (weather) + NOAA CO-OPS (tides) APIs.
  Requires customer geolocation permission.
{% endcomment %}

{%- liquid
  assign section_bg     = section.settings.color_bg
  assign section_text   = section.settings.color_text
  assign card_bg        = section.settings.color_card_bg
  assign title          = section.settings.title
  assign subtitle       = section.settings.subtitle
  assign show_section   = section.settings.show_section
-%}

{%- if show_section -%}
<link rel="stylesheet" href="{{ 'fishing-conditions.css' | asset_url }}">

<section
  class="huk-fc-section"
  id="section-{{ section.id }}"
  style="background-color: {{ section_bg }}; color: {{ section_text }};"
>
  <div class="huk-fc-section-container">

    {%- if title != blank or subtitle != blank -%}
    <div class="huk-fc-section-header">
      {%- if title != blank -%}
        <h2 class="huk-fc-section-title">
          <svg class="huk-fc-section-logo" viewBox="130 245 535 125" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path fill="currentColor" d="M286.84,251.66l-36.96-.02c-.72,0-1.24.7-1.03,1.39l1.45,4.68c1.61,5.18,2.16,10.17,2.16,19.78l-.02,14.92c0,.59-.48,1.08-1.08,1.08l-79.76.06c-.6,0-1.08-.48-1.08-1.08v-14.96c.02-9.6.57-14.59,2.19-19.78l1.47-4.68c.22-.69-.3-1.4-1.03-1.4l-36.46-.03c-.72,0-1.24.7-1.03,1.39l1.45,4.69c1.63,5.2,2.17,10.19,2.16,19.77l-.03,56.91c0,9.63-.56,14.63-2.18,19.8l-1.46,4.68c-.22.69.3,1.4,1.03,1.4l36.46.02c.73,0,1.25-.7,1.03-1.4l-1.47-4.68c-1.62-5.15-2.16-10.15-2.16-19.79v-14.77c.01-.59.5-1.08,1.09-1.08l79.76.05c.59,0,1.07.48,1.07,1.08v14.78c-.02,9.61-.57,14.61-2.18,19.79l-1.46,4.68c-.22.69.3,1.4,1.03,1.4l36.95.03c.72,0,1.24-.71,1.03-1.4l-1.46-4.68c-1.62-5.19-2.16-10.18-2.16-19.78l.04-57c0-9.57.55-14.56,2.18-19.78l1.47-4.68c.22-.69-.3-1.4-1.03-1.4"/><path fill="currentColor" d="M470.01,251.85l-48.5,39.22c-.79.64-.34,1.91.68,1.91l16.76-.03c.6,0,1.08.48,1.08,1.08v31.55c0,4.41-.5,6.8-1.68,7.98-1.19,1.19-3.6,1.63-8.05,1.68h-65.85c-4.39.07-6.85-.49-8.04-1.69-1.19-1.18-1.69-3.57-1.69-7.98v-72.88c0-.6-.48-1.08-1.07-1.08h-9.79s-7.06-.02-7.06-.02l-15.39-.02h0s-.86,0-.86,0c-.72,0-1.24.7-1.03,1.39l1.45,4.68c.88,2.82,1.43,5.63,1.76,9.12.18,2.76.26,5.9.26,9.72l-.02,54.01c0,22.07,9.37,29.9,35.86,29.92l77.1-.04c13.57,0,22.06-1.96,27.51-6.34,5.76-4.62,8.32-11.89,8.32-23.57v-77.81c0-.9-1.05-1.4-1.75-.83"/><path fill="currentColor" d="M656.09,360.12c.21-.2.32-.48.32-.76.03-.37-.1-.76-.43-1l-82.39-56.56,75.97-44.98,6.24-3.18c1.04-.49.68-2.05-.46-2.05,0,0-43.2-.04-55.4-.04-1.33,0-2.31,1.37-2.31,1.37-3.36,3.36-8.09,6.11-13.11,9.02l-23.44,13.97-22.52,13.38v-15.27c.04-2.74.11-5.12.25-7.26.33-3.49.88-6.3,1.77-9.13l1.45-4.68c.22-.69-.3-1.4-1.03-1.4h-1.88s-7.43,0-7.43,0v.09h-27.25c-.72-.01-1.24.69-1.03,1.38l1.46,4.68c1.61,5.17,2.15,10.05,2.14,19.67l-.03,57.12c0,9.65-.55,14.64-2.16,19.79l-1.47,4.68c-.22.69.3,1.4,1.03,1.4h36.75c.72.01,1.24-.69,1.03-1.38l-1.46-4.68c-1.62-5.21-2.17-10.2-2.17-19.78v-11.98s6.77-4,6.77-4l52.58,36.57c.07.06.15.13.21.17,1.71,1.19,3.27,2.44,4.61,3.78,0,0,.98,1.37,2.31,1.37,12.2,0,50.33-.04,50.33-.04.31,0,.55-.12.74-.29"/></svg>
          {{ title }}
        </h2>
      {%- endif -%}
      {%- if subtitle != blank -%}
        <span class="huk-fc-section-sub">{{ subtitle }}</span>
      {%- endif -%}
    </div>
    {%- endif -%}

    <div
      class="huk-fc-section-body"
      style="background-color: {{ card_bg }};"
    >
      <div class="huk-fc-inner">
        {%- comment -%}Populated by fishing-conditions.js{%- endcomment -%}
      </div>
    </div>

  </div>
</section>

<script src="{{ 'fishing-conditions.js' | asset_url }}" defer></script>
{%- endif -%}

{% schema %}
{
  "name": "Fishing Conditions",
  "tag": "section",
  "class": "huk-fishing-conditions",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Show this section",
      "default": true
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section heading",
      "default": "Today's Fishing Outlook"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subheading",
      "default": "Local weather, tides & fishing score — updated every 30 min"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "color_bg",
      "label": "Section background",
      "default": "#f0f9ff"
    },
    {
      "type": "color",
      "id": "color_text",
      "label": "Text color",
      "default": "#0f172a"
    },
    {
      "type": "color",
      "id": "color_card_bg",
      "label": "Card background",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Fishing Conditions"
    }
  ]
}
{% endschema %}
