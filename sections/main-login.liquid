{{ 'login-register.css' | asset_url | stylesheet_tag }}
<div class="row">
  <div class="small-12 columns">
    <div class="thb-form-container">
      <div class="thb-login-form" id="recover">
        <h4>{{ 'customer.recover_password.title' | t }}</h4>
        <p>{{ 'customer.recover_password.subtext' | t }}</p>
        {%- form 'recover_customer_password' -%}
          {%- if form.errors -%}
            <div class="form-notification error" id="RecoverEmail-email-error">
              {% render 'svg-icons' with 'thb-error' %}
              {{ form.errors.messages.form }}
            </div>
          {%- endif -%}
          <div class="field">
            <input
              type="email"
              value=""
              name="email"
              id="RecoverEmail"
              autocorrect="off"
              autocapitalize="off"
              autocomplete="email"
              placeholder="{{ 'customer.login_page.email' | t | escape }}"
              {% if form.errors %}
                aria-invalid="true"
                aria-describedby="RecoverEmail-email-error"
                autofocus
              {% endif %}
              class="full"
              placeholder="{{ 'customer.login_page.email' | t }}"
            >
            <label for="RecoverEmail">
              {{ 'customer.login_page.email' | t }}
            </label>
          </div>
          <button type="submit" class="button full">
            <span>{{ 'customer.login_page.submit' | t | escape }}</span>
          </button>
          <div class="switch-login-section">
            {% assign text_button_title = 'customer.login_page.cancel' | t %}
            {% render 'text-button', url: '#login', title: text_button_title %}
          </div>
        {%- endform -%}
      </div>
      <div class="thb-login-form" id="login">
        {% form 'customer_login', novalidate: 'novalidate', id: 'customer-login-form' %}
          <h4>{{ 'customer.login_page.login' | t }}</h4>
          <p>{{ 'customer.login_page.login_description' | t }}</p>
          {% if form.errors %}
            {%- comment -%}ADA FIX P1-5: server errors wrapped in role="alert" so NVDA announces on page reload{%- endcomment -%}
            <div class="form-notification error" role="alert" aria-live="assertive">
              {% render 'svg-icons' with 'thb-error' %}
              {{ form.errors | default_errors }}
            </div>
          {% endif %}
          <input type="hidden" name="return_to" value="/pages/rewards">

          <div class="field">
            <input
              type="email"
              name="customer[email]"
              id="customer-email"
              class="full {% if form.errors contains 'form' %}invalid{% endif %}"
              value=""
              autocomplete="email"
              autocorrect="off"
              autocapitalize="off"
              placeholder="{{ 'customer.login_page.email' | t }}"
              aria-required="true"
              aria-describedby="customer-email-error"
              {% if form.errors contains 'form' %}aria-invalid="true"{% else %}aria-invalid="false"{% endif %}
            >
            <label for="customer-email">{{ 'customer.login_page.email' | t }}</label>
            <span id="customer-email-error" role="alert" aria-live="polite" class="search-error-msg" style="display:block;color:#c0392b;font-size:13px;padding:4px 0 0;min-height:1em;"></span>
          </div>
          <div class="field">
            <input
              type="password"
              name="customer[password]"
              id="customer-password"
              class="full {% if form.errors contains 'form' %}invalid{% endif %}"
              value=""
              placeholder="{{ 'customer.login_page.password' | t }}"
              aria-required="true"
              aria-describedby="customer-password-error"
              {% if form.errors contains 'form' %}aria-invalid="true"{% else %}aria-invalid="false"{% endif %}
            >
            <label for="customer-password">{{ 'customer.login_page.password' | t }}</label>
            <span id="customer-password-error" role="alert" aria-live="polite" class="search-error-msg" style="display:block;color:#c0392b;font-size:13px;padding:4px 0 0;min-height:1em;"></span>
          </div>
          <div class="field">
            <button type="submit" class="button full">
              <span>{{ 'customer.login_page.sign_in' | t }}</span>
            </button>
          </div>
          <div class="switch-login-section">
            {{ 'customer.login_page.dont_have_an_account' | t }}
            {% assign text_button_title = 'customer.login_page.create_account' | t %}
            {% render 'text-button', url: routes.account_register_url, title: text_button_title %}
            <div>
              {% assign text_button_title = 'customer.login_page.forgot_password' | t %}
              {% render 'text-button', url: '#recover', title: text_button_title %}
            </div>
          </div>
        {% endform %}
      </div>
    </div>
  </div>
</div>
<script>
// ADA FIX P1-5: client-side validation — NVDA announces errors immediately without page reload
(function() {
  var form = document.getElementById('customer-login-form');
  if (!form) return;
  form.addEventListener('submit', function(e) {
    var emailInput = document.getElementById('customer-email');
    var passwordInput = document.getElementById('customer-password');
    var emailError = document.getElementById('customer-email-error');
    var passwordError = document.getElementById('customer-password-error');
    var valid = true;

    if (!emailInput.value.trim()) {
      emailInput.setAttribute('aria-invalid', 'true');
      emailError.textContent = 'Please enter your email address.';
      if (valid) { emailInput.focus(); }
      valid = false;
    } else {
      emailInput.setAttribute('aria-invalid', 'false');
      emailError.textContent = '';
    }

    if (!passwordInput.value.trim()) {
      passwordInput.setAttribute('aria-invalid', 'true');
      passwordError.textContent = 'Please enter your password.';
      if (valid) { passwordInput.focus(); }
      valid = false;
    } else {
      passwordInput.setAttribute('aria-invalid', 'false');
      passwordError.textContent = '';
    }

    if (!valid) e.preventDefault();
  });
})();
</script>
