{% comment %}
** Divider - homepage partial **
- Draggable section
{% endcomment %}
{% render 'include-divider' %}

{% schema %}

{
  "name": "Divider",
  "class": "divider-section",
  "settings": [
    {
      "type": "range",
      "id": "divider_spacing",
      "min": 0,
      "max": 20,
      "step": 1,
      "unit": "em",
      "label": "Desktop Space",
      "default": 2
    },
    {
      "type": "range",
      "id": "divider_spacing_mobile",
      "min": 0,
      "max": 20,
      "step": 1,
      "unit": "em",
      "label": "Mobile Space",
      "default": 2
    },
    {
      "type": "checkbox",
      "id": "divider_border",
      "label": "Show border",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Divider",
      "category": "Layout",
      "settings": {

      }
    }
  ]
}

{% endschema %}