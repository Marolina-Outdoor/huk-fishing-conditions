    "8ab8f1f0-7339-452e-9f95-73816fef5c9e": {
      "type": "testimonials",
      "blocks": {
        "template--14745674219578__8ab8f1f0-7339-452e-9f95-73816fef5c9e-quote-3": {
          "type": "quote",
          "settings": {
            "stars": "",
            "text": "\"The new Icon shirt is Huk's best shirt yet.  Being a south Florida Captain the heat is what will keep you from wanting to go out. The I.C.E. tech is legit.  You can feel it cooling your skin allowing me to stay comfortable all day on the water.\"",
            "author": "Thomas L."
          }
        },
        "quote_bUj6VJ": {
          "type": "quote",
          "settings": {
            "stars": "",
            "text": "\"Great fitting shirt! The hood is big enough to cover the sides of your face. Very cool even in 95 degrees. Light and comfortable material, with great sun protection.\"",
            "author": "Tod H."
          }
        },
        "template--14745674219578__8ab8f1f0-7339-452e-9f95-73816fef5c9e-quote-1": {
          "type": "quote",
          "settings": {
            "stars": "",
            "text": "\"I had a great experience! It's always a good feeling when a product lives up to its description. Staying comfortable and protected from the elements is key for any successful fishing trip. A good hoodie can make all the difference when you're out on the water. It sounds like I found a winner wearing the HUK Icon hoodie.\"",
            "author": "Bebee M."
          }
        },
        "template--14745674219578__8ab8f1f0-7339-452e-9f95-73816fef5c9e-quote-2": {
          "type": "quote",
          "settings": {
            "stars": "",
            "text": "\"The Huk Icon Performance Hoodie is as essential as the hook on the end of your line. Plain and simple, get it.\"",
            "author": "Shane E."
          }
        }
      },
