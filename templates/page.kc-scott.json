{"sections":{"567fa266-e3a3-4d42-8bd7-d5c0c15798dd":{"type":"image-with-text-overlay","blocks":{"template--14745674219578__567fa266-e3a3-4d42-8bd7-d5c0c15798dd-heading-1":{"type":"heading","settings":{"text":"INSPIRED BY NATURE<br>KC SCOTT X HUK","heading_size":"h1"}}},"block_order":["template--14745674219578__567fa266-e3a3-4d42-8bd7-d5c0c15798dd-heading-1"],"custom_css":[],"settings":{"image":"shopify:\/\/shop_images\/KC-Scott-Header.jpg","mobile_image":"shopify:\/\/shop_images\/KC-Scott-Mobile.jpg","image_parallax":true,"desktop_height":"desktop-height-450","mobile_height":"mobile-height-350","image_focal_point_y":50,"mob_image_focal_point_y":50,"enable_focal_control":false,"full_width":true,"content_width":"medium","content_position":"bottom-center","text_alignment":"center","text_color":"#ffffff","overlay_color":"#35393d","overlay_opacity":25,"disable_top_spacing":true,"disable_bottom_spacing":true}},"rich_text_GFVwhC":{"type":"rich-text","blocks":{"heading_mfCkw6":{"type":"heading","settings":{"text":"IT'S NOT ONLY THAT YOU'RE WEARING A PIECE OF CLOTHING WITH ARTWORK ON IT - THERE'S A STORY BEHIND IT, THERE'S A LIFESTYLE THAT WE ALL SHARE, AND THAT'S THE COOL THING ABOUT PARTNERING WITH HUK.","marker_style":"style1","size":"h3","marker_color":"#fd6262"}},"text_w8UnhU":{"type":"text","settings":{"text":"<p><em>-KC SCOTT<\/em><\/p>","size":"text-size-large"}},"button_Rp9ajX":{"type":"button","disabled":true,"settings":{"link_label":"Shop the Collection","link":"shopify:\/\/collections\/kc-scott-collection"}}},"block_order":["heading_mfCkw6","text_w8UnhU","button_Rp9ajX"],"custom_css":["{background-color: #f7f4ef;}","p {color: #0e4175;}",".button {margin-top: 10px;}"],"settings":{"id":"","text_width":"xlarge","text_position":"right","text_alignment":"right","color_bg":"#f7f4ef","color_heading":"#0E4175","color_text":"#0581ff","color_links":"#0581ff","full_bleed_layout":true,"disable_top_spacing":true,"disable_bottom_spacing":true}},"collection_list_BTxgxp":{"type":"collection-list","name":"Collection list","settings":{"heading":"The KC Scott Assortment","marker_style":"style1","description":"<p>From bold, custom prints to lifelike underwater graphics, KC Scott's Huk collection turns your passion into wearable art for every adventure.<\/p>","heading_size":"medium","collection_list":["mens-kc-scott-tee-2-0","kc-scott-for-her","kc-scott-for-kids"],"image_ratio":"portrait","collection_layout":"grid","style":"style2","columns_desktop":3,"columns_mobile":"1","show_progress_bar":true,"mobile_swipe":true,"heading_position":"bottom-center","marker_color":"#fd6262","text_color":"#ffffff","overlay_color":"rgba(0,0,0,0)","overlay_opacity":10,"disable_top_spacing":false,"disable_bottom_spacing":true}},"image_with_text_EiGFtq":{"type":"image-with-text","blocks":{"heading_cjPrfx":{"type":"heading","settings":{"text":"From Water to Wear","marker_style":"style1","heading_size":"h3","marker_color":"#fd6262"}},"text_gr8Cw7":{"type":"text","settings":{"text":"<p>Those times in your life when you laugh because you’re so excited - that’s how I feel when I get in the water - the beauty of it and the perspective that it gives me as an artist is incredible. Then to be able to recreate the experience, and actually be able to carry on the stories from the water to the creation of the artwork and then to the people that are buying my artwork on the clothing, it takes it a whole other level. <\/p>"}}},"block_order":["heading_cjPrfx","text_gr8Cw7"],"name":"Image with text","settings":{"image":"shopify:\/\/shop_images\/DSC00078.png","use_video":false,"video":"","video_autoplay":false,"height":"large","desktop_image_width":"medium","full_width":true,"layout":"text_first","content_position":"text-left","column_spacing":"medium","color_bg":"#ffffff","color_text":"#0e4174","color_border":"#e2e2e2","disable_top_spacing":false,"disable_bottom_spacing":true}},"video_mnpttM":{"type":"video","settings":{"heading":"","marker_style":"style1","description":"","full_width":false,"video":"","video_hosted":"shopify:\/\/files\/videos\/KC ART OF NATURE DOCO FINAL _preview.mov","video_autoplay":true,"aspect_ratio":"16-9","marker_color":"#fd6262","disable_top_spacing":false,"disable_bottom_spacing":false}},"image_with_text_overlay_6UzWMi":{"type":"image-with-text-overlay","blocks":{"subheading_9inRYf":{"type":"subheading","settings":{"text":"A FALL 25 EXCLUSIVE PATTERN"}},"heading_zkmWWC":{"type":"heading","settings":{"text":"TROPHY ROOM CAMO","heading_size":"h1-xlarge"}},"text_gNhG44":{"type":"text","settings":{"text":"<p>\"When designing for the collection, I wanted to take a throwback camo and reimagine it for Huk's lifestyle. When you look closely there's trophy fish hidden in the pattern, hitting a custom take on the vintage vibe.\" <\/p>","description_size":"medium"}}},"block_order":["subheading_9inRYf","heading_zkmWWC","text_gNhG44"],"disabled":true,"name":"Image with text overlay","settings":{"image":"shopify:\/\/shop_images\/FA2500224_SALT_trophy_room_SKY.jpg","image_parallax":false,"desktop_height":"desktop-height-450","mobile_height":"mobile-height-500","image_focal_point_y":50,"mob_image_focal_point_y":50,"enable_focal_control":false,"full_width":true,"content_width":"large","content_position":"bottom-center","text_alignment":"center","text_color":"#0e4174","overlay_color":"#9fa3a7","overlay_opacity":30,"disable_top_spacing":false,"disable_bottom_spacing":true}},"collection_tabs_xeNMgg":{"type":"collection-tabs","blocks":{"collection_za9Cjb":{"type":"collection","settings":{"collection":"kc-scott-collection","show_alternate_images":false,"enable_promotion":true,"image":"shopify:\/\/shop_images\/Airweight-Landing-Collection.jpg","title":"","text":"","link_label":"SHOP NOW","content_position":"bottom-center","text_alignment":"center","link":"shopify:\/\/collections\/airweight-collection","use_text_button":false,"block_link":"shopify:\/\/collections\/airweight-collection","overlay_color":"#000000","overlay_opacity":12}}},"block_order":["collection_za9Cjb"],"disabled":true,"settings":{"heading":"Shop the Collection","marker_style":"style1","description":"","product_limit":16,"columns_desktop":4,"show_progress_bar":false,"marker_color":"#ffffff","bg-color":"#ffffff","disable_top_spacing":false,"disable_bottom_spacing":false}},"8ab8f1f0-7339-452e-9f95-73816fef5c9e":{"type":"testimonials","blocks":{"template--14745674219578__8ab8f1f0-7339-452e-9f95-73816fef5c9e-quote-3":{"type":"quote","settings":{"stars":"","text":"\"The new Icon shirt is Huk's best shirt yet.  Being a south Florida Captain the heat is what will keep you from wanting to go out. The I.C.E. tech is legit.  You can feel it cooling your skin allowing me to stay comfortable all day on the water.\"","author":"Thomas L."}},"quote_bUj6VJ":{"type":"quote","settings":{"stars":"","text":"\"Great fitting shirt! The hood is big enough to cover the sides of your face. Very cool even in 95 degrees. Light and comfortable material, with great sun protection.\"","author":"Tod H."}},"template--14745674219578__8ab8f1f0-7339-452e-9f95-73816fef5c9e-quote-1":{"type":"quote","settings":{"stars":"","text":"\"I had a great experience! It's always a good feeling when a product lives up to its description. Staying comfortable and protected from the elements is key for any successful fishing trip. A good hoodie can make all the difference when you're out on the water. It sounds like I found a winner wearing the HUK Icon hoodie.\"","author":"Bebee M."}},"template--14745674219578__8ab8f1f0-7339-452e-9f95-73816fef5c9e-quote-2":{"type":"quote","settings":{"stars":"","text":"\"The Huk Icon Performance Hoodie is as essential as the hook on the end of your line. Plain and simple, get it.\"","author":"Shane E."}}},"block_order":["template--14745674219578__8ab8f1f0-7339-452e-9f95-73816fef5c9e-quote-3","quote_bUj6VJ","template--14745674219578__8ab8f1f0-7339-452e-9f95-73816fef5c9e-quote-1","template--14745674219578__8ab8f1f0-7339-452e-9f95-73816fef5c9e-quote-2"]