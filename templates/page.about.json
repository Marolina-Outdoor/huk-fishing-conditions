    "timeline_BFHGp8": {
      "type": "timeline",
      "blocks": {
        "milestone_9QdAYh": {
          "type": "milestone",
          "settings": {
            "milestone_image": "shopify:\/\/shop_images\/Rectangle_101.jpg",
            "milestone_image_alignment": "left",
            "milestone_title": "Bold decisions create a big brand",
            "milestone_description": "Four friends decided chase an idea - to build a company that supported their passion for fishing all year long and to design best-in-class gear that looked good on and off the water.",
            "milestone_date": "2014"
          }
        },
        "milestone_DKGxPD": {
          "type": "milestone",
          "settings": {
            "milestone_image": "shopify:\/\/shop_images\/Rectangle_102.jpg",
            "milestone_image_alignment": "right",
            "milestone_title": "THE BEGINNING OF HUK",
            "milestone_description": "Huk was born with the launch of the Icon shirt, a new aggressive take on the performance fishing market. With bold colors and big branding, the guys rolled up to events with wrapped Freemans, and in that moment Huk shook up the space with an attitude that hadn't been seen before.",
            "milestone_date": "2015"
          }
        },
        "milestone_8HR7JN": {
          "type": "milestone",
          "settings": {
            "milestone_image": "shopify:\/\/shop_images\/Rectangle_103.jpg",
            "milestone_image_alignment": "left",
            "milestone_title": "THE ICON MAKES WAVES",
            "milestone_description": "The Icon goes national with distribution hitting all 50 states in only 3 years. Along with the Icon, Huk now represented a truly technical line of apparel built to allow serious anglers to fish harder and in more comfort.",
            "milestone_date": "2018"
          }
        },
        "milestone_KgbY66": {
          "type": "milestone",
          "settings": {
            "milestone_image": "shopify:\/\/shop_images\/E4A6839rt_CC_medium_82e17a10-ad37-42c5-b09a-a666f1c51890.jpg",
            "milestone_image_alignment": "right",
            "milestone_title": "TIDE POINT ENTERS THE CHAT",
            "milestone_description": "A fresh take on an old school shirt. After building the brand through performance knits, it was time to take on an industry giant - the woven button-down fishing shirt. Creating a knock off wasn’t our style, so we developed a cleaner, faster, more modern fit button down that delivered exceptional performance without the weight, do-dads, and giant baffles that our competition relied on to perform. The Tide Point was a hit and is still one of our best sellers today.",
            "milestone_date": "2019"
          }
        },
        "milestone_jd4Pp3": {
          "type": "milestone",
          "settings": {
            "milestone_image": "shopify:\/\/shop_images\/FL_23Huk_547-_medium_f80b7403-4b60-4c53-a220-be7507b3fb72.jpg",
            "milestone_image_alignment": "left",
            "milestone_title": "A COLLECTION IS BORN",
            "milestone_description": "Recognizing the energy around our performance driven approach to apparel, we began to build out new products to support the rest of our consumer’s lifestyle. We took inspiration from our performance fabrics and expanded into new water-inspired lifestyle categories that did more than just look good. Launching the Kona shirt opened the door to a whole new look for Huk - on the boat performance cred met off the boat sharp looks. The Kona has grown to become our customer's favorite everyday shirt and is offered in over 30 colors and prints.",
            "milestone_date": "2020"
          }
        },
        "milestone_4ArijA": {
          "type": "milestone",
          "settings": {
            "milestone_image": "shopify:\/\/shop_images\/Rogue_Wave_Sole.jpg",
            "milestone_image_alignment": "right",
            "milestone_title": "A GAME-CHANGING BOOT",
            "milestone_description": "2020 was a big year marking our entry into the waterproof boot category with the new Rogue Wave. Leveraging over two years of feedback and testing with guides and captains across the country, our proprietary Grip-X outsole was designed to be the ultimate in on-the-water stability, with a multi-directional traction support and all-day comfort.",
            "milestone_date": "2020"
          }
        },
        "milestone_YYimFQ": {
          "type": "milestone",
          "settings": {
            "milestone_image": "shopify:\/\/shop_images\/Rectangle_104.jpg",
            "milestone_image_alignment": "left",
            "milestone_title": "A REDESIGN OF AN ICON",
            "milestone_description": "Our 10th anniversary brought a revamp to the shirt that started it all. With a redesigned expanded full back mesh panel and hood, updated raglan sleeves to increase range of motion, and a modern fit (while maintaining 50+ UPF protection), the Icon is stronger than ever.  We continue to innovate for the anglers that trust us to gear them up to be First to the Fish.",
            "milestone_date": "2024"
          }
        }
      },
      "block_order": [
        "milestone_9QdAYh",
