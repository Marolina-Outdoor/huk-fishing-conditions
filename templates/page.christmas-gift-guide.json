xt_alignment":"left","link":"shopify:\/\/collections\/gifts-for-looking-good-off-the-water","use_text_button":false,"block_link":"","overlay_color":"#000000","overlay_opacity":70}}},"block_order":["collection_TcbYVq","collection_ALJDF9"],"settings":{"heading":"A GIFT FOR HIS ADVENTURES","marker_style":"style1","bg_position":"align-right","bg_color":"#f7f4ef","product_limit":3,"columns_desktop":4,"show_progress_bar":true,"marker_color":"#fd6262","disable_top_spacing":false,"disable_bottom_spacing":true}},"collection_tabs_XCzAyq":{"type":"collection-tabs","blocks":{"collection_GBg4GL":{"type":"collection","settings":{"collection":"chasing-the-winter-bite","show_alternate_images":false,"enable_promotion":true,"image":"shopify:\/\/shop_images\/Huk_Christmas_30_1000x667_crop_top_jpg.jpg","title":"Men's Cold Weather Gear","text":"","link_label":"Shop the Collection","content_position":"bottom-left","text_alignment":"left","link":"shopify:\/\/collections\/chasing-the-winter-bite","use_text_button":true,"block_link":"","overlay_color":"#000000","overlay_opacity":0}},"collection_mrcAYX":{"type":"collection","settings":{"collection":"cabin-time-cozy","show_alternate_images":false,"enable_promotion":true,"image":"shopify:\/\/shop_images\/Gift_Guide_187.jpg","title":"Cabin Time Cozy","text":"","link_label":"Shop the Collection","content_position":"bottom-left","text_alignment":"left","link":"shopify:\/\/collections\/cabin-time-cozy","use_text_button":true,"block_link":"","overlay_color":"#000000","overlay_opacity":40}}},"block_order":["collection_GBg4GL","collection_mrcAYX"],"disabled":true,"settings":{"heading":"Perfect Gifts for Every Angler","marker_style":"style1","description":"","product_limit":6,"columns_desktop":4,"show_progress_bar":true,"marker_color":"#fd6262","bg-color":"#ffffff","disable_top_spacing":false,"disable_bottom_spacing":false}},"rich_text_mgW6FY":{"type":"rich-text","blocks":{"image_xyh4NT":{"type":"image","settings":{"image":"shopify:\/\/shop_images\/Ice.png"}},"heading_pDzTpj":{"type":"heading","settings":{"text":"Holiday Returns\/Exchanges","marker_style":"style1","size":"h3","marker_color":"#fd6262"}},"text_Y8xTxb":{"type":"text","settings":{"text":"<p>We want your holiday shopping experience to be as joyful as the season itself! That’s why we’ve extended our return and exchange window to make sure you (or your gift recipient) are completely satisfied. <\/p><p>Any purchase made 11\/1\/25 - 12\/25\/25 is eligible for return or exchange through January 31, 2026.<\/p>","size":"text-size-regular"}}},"block_order":["image_xyh4NT","heading_pDzTpj","text_Y8xTxb"],"settings":{"id":"","text_width":"xlarge","text_position":"center","text_alignment":"center","color_bg":"#2b3a27","color_heading":"#F7F4EF","color_text":"#f7f4ef","color_links":"#f7f4ef","full_bleed_layout":true,"disable_top_spacing":true,"disable_bottom_spacing":true}},"custom_shop_by_collection_tm8KVE":{"type":"custom-shop-by-collection","blocks":{"collection_cqbkFj":{"type":"collection","settings":{"collection":"gifts-for-your-lady-that-outfishes-you","enable_promotion":true,"image":"shopify:\/\/shop_images\/gifts_for_her_-_on_the_water-5.png","title":"She’ll Outfish You. Again.","text":"Built for the woman who lives for the chase and never misses the bite.","link_label":"Shop The Guide","content_position":"bottom-left","text_alignment":"left","link":"shopify:\/\/collections\/gifts-for-your-lady-that-outfishes-you","use_text_button":false,"block_link":"","overlay_color":"#ffffff","overlay_opacity":16}},"collection_36MLq4":{"type":"collection","settings":{"collection":"gifts-for-women-that-love-to-travel","enable_promotion":true,"image":"shopify:\/\/shop_images\/gifts_for_her_-_on_the_water-4.png","title":"Cozy Meets Carry-On","text":"For the woman who’s always chasing the next horizon. Wrap her in soft layers made to move, lounge, and explore in comfort.","link_label":"Shop The Guide","content_position":"bottom-left","text_alignment":"left","link":"shopify:\/\/collections\/gifts-for-women-that-love-to-travel","use_text_button":false,"block_link":"","overlay_color":"#000000","overlay_opacity":7}}},"block_order":["collection_cqbkFj","collection_36MLq4"],"settings":{"heading":"A GIFT FOR HER ADVENTURES","marker_style":"style1","bg_position":"align-right","bg_color":"#f7f4ef","product_limit":3,"columns_desktop":4,"show_progress_bar":true,"marker_color":"#fd6262","disable_top_spacing":false,"disable_bottom_spacing":true}},"collapsible_content_kfrN7q":{"type":"collapsible-content","blocks":{"collapsible_tab_eF4BzV":{"type":"collapsible_tab","settings":{"heading":"Do you offer gift wrapping or personalization options?","open":false,"content":"<p>We don’t offer gift wrapping or personalization on our orders. However, you can add a personalized note on gift cards (delivered via email).<\/p>","page":""}},"collapsible_tab_DYdqDX":{"type":"collapsible_tab","settings":{"heading":"When is the last day to place an order to ensure delivery before Christmas?","open":false,"content":"<p>For standard orders, we suggest you place your order before Tuesday 12\/16 at 12pm EST. If you choose an expedited service, the last day for 2-day shipping is Thursday 12\/18, or overnight by Friday 12\/19 to ensure there is plenty of time for order processing.<\/p>","page":""}},"collapsible_tab_hwhAjy":{"type":"collapsible_tab","settings":{"heading":"What is your holiday return\/exchange window?","open":false,"content":"<p>Any purchases made from 11\/1\/25 - 12\/25\/25 is eligible for return or exchange through January 31, 2026 <\/p><p>*A link for a gift return\/exchange can be provided upon request (the gift purchasers email must be provided) <\/p><p>Our normal conditions for returns\/exchanges apply: <\/p><p>We will gladly accept returns and exchanges on all purchases made on our website within 30 days of the purchase date. Items must be in the original, salable condition, unworn with tags attached, and for footwear with the original box in new condition. Final sale items cannot be returned or exchanged. The shipping cost is non-refundable unless the item is found to be defective or damaged. Undergarments and Gaiters are final sale and cannot be returned. <\/p><p>If you are returning items from multiple orders, they must be shipped with their corresponding shipping label to expedite your returns process. Our returns process is tied directly to the bar code on each shipping label. Therefore, returning items under a single label will cause significant processing delays.  <\/p><p>When we receive your returned item(s) we will issue your refund. Please allow one billing cycle for credit card refunds to appear on your statement. Returns are generally processed within 5-7 business days of receipt. <\/p>","page":""}},"collapsible_tab_kbFpRg":{"type":"collapsible_tab","settings":{"heading":"An item I want is out of stock. Will it be back in stock before the holidays?","open":false,"content":"<p>We do our best to keep your favorites in stock, but some items go quick! If there is something you really want, please ask us about it using our email support@huk.com and we will get back to you as quickly as possible! <\/p><p>*<em>Please note: if an item is in our outlet section, it will not be coming back in stock.<\/em> <\/p>","page":""}},"collapsible_tab_KDJDFL":{"type":"collapsible_tab","disabled":true,"settings":{"heading":"Can I return or exchange an item bought during the holiday season?","open":false,"content":"<p>Yes, as long as the return meets our return guidelines. Gift return\/exchanges can be made by providing the purchasers email address so that we can look up the order. Purchases made through 12\/25\/25 are eligible for return or exchange by 1\/31\/26.<\/p>","page":""}},"collapsible_tab_QX74YN":{"type":"collapsible_tab","settings":{"heading":"Where is my order? How can I track my shipment?","open":false,"content":"<p>The two quickest ways to check the confirmation email from Huk Gear (check your spam!) or log-in to your Huk Gear account and view recent orders. If neither of those options work, please email us at <strong>support@huk<\/strong> with your <strong>order number or the email you used to place the order, <\/strong>and we will look up your order information for you!<em> <\/em> <\/p><p><em>*Please note that email volume does increase during this time of year, please only send one email and we will respond as quickly as possible!<\/em> <\/p>","page":""}}},"block_order":["collapsible_tab_eF4BzV","collapsible_tab_DYdqDX","collapsible_tab_hwhAjy","collapsible_tab_kbFpRg","collapsible_tab_KDJDFL","collapsible_tab_QX74YN"],"custom_css":["{background-color: #efe6dd;}"],"settings":{"id":"","heading":"Holiday FAQs","marker_style":"style1","description":"","color_bg":"#f7f4ef","color_heading":"#2b3a27","marker_color":"#fd6262","color_text":"#2b3a27","color_links":"#2c2d2e","color_border":"#dadce0","disable_top_spacing":false,"disable_bottom_spacing":false,"section-reverse":false,"section-reverse-mobile":false}}},"order":["slideshow_UMcpCD","567fa266-e3a3-4d42-8bd7-d5c0c15798dd","multicolumn_TpwhY8","countdown_banner_YcxEDR","media_grid_9Cbd93","image_with_text_overlay_cG3k66","gallery_XHttMm","collection_list_NU9mcM","custom_shop_by_collection_gLGfHE","collection_tabs_XCzAyq","rich_text_mgW6FY","custom_shop_by_collection_tm8KVE","collapsible_content_kfrN7q"]}