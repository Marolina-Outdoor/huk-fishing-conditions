    "8ab8f1f0-7339-452e-9f95-73816fef5c9e": {
      "type": "testimonials",
      "blocks": {
        "template--14745674219578__8ab8f1f0-7339-452e-9f95-73816fef5c9e-quote-3": {
          "type": "quote",
          "settings": {
            "stars": "",
            "text": "\"I have tried all of the other major brands of deck boot and huk’s have outlasted the test. I live on the east coast and wear these 12 months out of the year.\"",
            "author": "Christopher M."
          }
        },
        "template--14745674219578__8ab8f1f0-7339-452e-9f95-73816fef5c9e-quote-1": {
          "type": "quote",
          "settings": {
            "stars": "",
            "text": "“I wore them from the time I left the house for about seven in the morning to when i got home got about 7 at night I found these boots so comfortable compared to my last boots. I didn’t have the same ankle pain I was having all day before they were very comfortable I highly recommend these boots to anybody on their feet all day.”",
            "author": "Landon F."
          }
        },
        "template--14745674219578__8ab8f1f0-7339-452e-9f95-73816fef5c9e-quote-2": {
          "type": "quote",
          "settings": {
            "stars": "",
            "text": "\"I love these boots! They fit well and provide the protection I need in the pluff mud \/ around oysters on the edge of the water while fishing.\"",
            "author": "Andrew P."
          }
        }
      },
